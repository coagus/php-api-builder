# Database
DB_DRIVER=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=demo_api
DB_USERNAME=root
DB_PASSWORD=secret

# JWT
JWT_ALGORITHM=HS256
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_ISSUER=demo-api
JWT_AUDIENCE=demo-api

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# App
APP_PORT=8000
DB_PORT=3306
